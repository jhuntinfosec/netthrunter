{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIH-C IOC Collection",
  "description": "Standard schema for passing indicators between AIH-C modules",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "source_module": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["source_module", "generated_at"]
    },
    "indicators": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["ip", "domain", "url", "jarm", "hash", "email", "asn"]
          },
          "value": { "type": "string" },
          "context": {
            "type": "object",
            "description": "Any additional enrichment context (e.g. WHOIS, JARM matches)"
          }
        },
        "required": ["type", "value"]
      }
    }
  },
  "required": ["metadata", "indicators"]
}
